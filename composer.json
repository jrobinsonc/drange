{
  "name": "jrdev/drange",
  "type": "library",
  "description": "Efficiently manage non-contiguous integer ranges with automatic merging and set operations",
  "keywords": [
    "range",
    "ranges",
    "discontinuous",
    "non-contiguous",
    "integer",
    "merge",
    "data-structure",
    "set-operations",
    "intersection",
    "gaps",
    "allocation"
  ],
  "homepage": "https://github.com/jrobinsonc/drange/blob/master/README.md",
  "license": "MIT",
  "authors": [
    {
      "name": "Jose Robinson",
      "email": "hi@joserobinson.com",
      "homepage": "http://joserobinson.com"
    }
  ],
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpmd/phpmd": "^2.15",
    "pdepend/pdepend": "^2.16",
    "squizlabs/php_codesniffer": "^4.0",
    "codeception/codeception": "^5.3",
    "codeception/module-asserts": "^3.2",
    "captainhook/captainhook": "^5.29"
  },
  "scripts": {
    "phpmd": "vendor/bin/phpmd tests/unit/,src/ text phpmd.xml",
    "phpcs": "vendor/bin/phpcs --standard=PSR2 tests/unit/ src/",
    "codecept": "vendor/bin/codecept run",
    "coverage": "vendor/bin/codecept run --coverage --coverage-html",
    "test": [
      "@codecept",
      "@phpcs",
      "@phpmd"
    ]
  },
  "support": {
    "issues" : "https://github.com/jrobinsonc/drange/issues",
    "source": "https://github.com/jrobinsonc/drange"
  },
  "autoload": {
    "psr-4": {
      "jrdev\\": "src/"
    }
  }
}
